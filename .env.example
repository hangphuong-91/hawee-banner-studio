# HAWEE Banner Studio — Environment Variables
# Copy to .env.local for local development

# Optional: Restrict CORS on /api/openai proxy
# Set to your Vercel deployment URL in production
ALLOWED_ORIGIN=https://hawee-banner-studio.vercel.app

# Note: OpenAI API key is entered by the user in the app UI
# and stored in their browser's localStorage.
# No server-side OpenAI key needed.
